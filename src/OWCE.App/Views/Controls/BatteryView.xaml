<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OWCE.Views.Controls.BatteryView">
    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto" ColumnSpacing="4">
        <!-- Battery icon body -->
        <Border Grid.Column="0"
                WidthRequest="32" HeightRequest="16"
                BackgroundColor="Transparent"
                Stroke="{StaticResource TextSecondary}"
                StrokeThickness="1.5"
                StrokeShape="RoundRectangle 2">
            <BoxView x:Name="FillBox"
                     HorizontalOptions="Start"
                     HeightRequest="12"
                     WidthRequest="28"
                     Margin="2"
                     CornerRadius="1" />
        </Border>
        <!-- Battery terminal nub -->
        <BoxView Grid.Column="1"
                 WidthRequest="3" HeightRequest="8"
                 VerticalOptions="Center"
                 Color="{StaticResource TextSecondary}" />
        <!-- Percentage label -->
        <Label Grid.Column="2"
               x:Name="PercentLabel"
               FontFamily="SairaBold"
               FontSize="14"
               TextColor="{StaticResource TextPrimary}"
               VerticalOptions="Center" />
    </Grid>
</ContentView>
