<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand Colors -->
    <Color x:Key="OWCEPrimary">#00B4D8</Color>
    <Color x:Key="OWCESecondary">#0077B6</Color>
    <Color x:Key="OWCEAccent">#90E0EF</Color>
    <Color x:Key="OWCEBackground">#03045E</Color>
    <Color x:Key="OWCEDark">#000000</Color>

    <!-- Status Colors -->
    <Color x:Key="BatteryGreen">#2ECC71</Color>
    <Color x:Key="BatteryYellow">#F39C12</Color>
    <Color x:Key="BatteryRed">#E74C3C</Color>
    <Color x:Key="RegenBlue">#3498DB</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#B0BEC5</Color>

</ResourceDictionary>
