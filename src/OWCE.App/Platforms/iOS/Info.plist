<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>UIDeviceFamily</key>
    <array>
        <integer>1</integer>
        <integer>2</integer>
    </array>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>armv7</string>
        <string>bluetooth-le</string>
    </array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>XSAppIconAssets</key>
    <string>Assets.xcassets/appicon.appiconset</string>

    <!-- BLE Usage Descriptions (required by App Store review) -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>OWCE uses Bluetooth to connect to your Onewheel and display live ride data.</string>
    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>OWCE uses Bluetooth to connect to your Onewheel and display live ride data.</string>

    <!-- Location Usage Descriptions (for GPS ride tracking) -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>OWCE uses your location to record your ride route and calculate distance.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>OWCE uses your location in the background to continue recording your ride when the app is minimized.</string>

    <!-- Background Modes: BLE + Location + BGTaskScheduler -->
    <key>UIBackgroundModes</key>
    <array>
        <string>bluetooth-central</string>
        <string>location</string>
        <string>processing</string>
    </array>

    <!-- BGTaskScheduler: BLE keepalive task (fixes issue #111 - iOS background disconnect) -->
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>app.owce.ble-keepalive</string>
    </array>
</dict>
</plist>
